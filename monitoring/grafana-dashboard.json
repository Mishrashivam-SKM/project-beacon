{
  "title": "Project Beacon Dashboard",
  "panels": [
    {
      "type": "stat",
      "title": "Application Uptime",
      "targets": [
        {
          "expr": "up{job=\"beacon-app\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Duration",
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])"
        }
      ]
    }
  ]
}
